# Blood Arena WhatsApp bot — copy to ".env" and fill in.
# এই মান দুটি config.php-এর WA_BOT_SECRET ও WA_BOT_URL-এর সাথে মিলতে হবে।

# PHP ↔ Node শেয়ার্ড সিক্রেট (config.php-এর WA_BOT_SECRET-এর সাথে হুবহু এক)
WA_BOT_SECRET=change-me-to-a-long-random-string

# HTTP API ভেতরে কোন পোর্টে শুনবে (reverse proxy এতে forward করবে)
PORT=3001

# কোন interface-এ bind করবে। reverse proxy ব্যবহার করলে 127.0.0.1 রাখুন
# (বাইরে থেকে 3001 খোলা থাকবে না)। সরাসরি খুলতে চাইলে 0.0.0.0
HOST=127.0.0.1

# whatsapp-web.js session কোথায় cache হবে (default ./.wwebjs_auth)
WA_SESSION_DIR=./.wwebjs_auth
